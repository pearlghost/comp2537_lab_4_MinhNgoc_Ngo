<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pokémon Demo</title>

    <!-- Bootstrap (UI framework) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link href="./css/style.css" rel="stylesheet" />
</head>

<body class="bg-light">

    <!-- ================= PAGE HEADER ================= -->
    <div class="container py-4">
        <h1 class="text-center mb-5 display-3 fw-bold">Pokémon Explorer</h1>

        <!-- Pokémon Grid -->
        <div id="pokemon-container" class="row g-4"></div>

        <!-- Load Button -->
        <div class="text-center my-4">
            <button id="loadMoreBtn" class="btn btn-primary btn-lg">
                Load More Pokémon
            </button>
        </div>

        <!-- Spinner Loader -->
        <div id="loader" class="text-center py-4 d-none">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Loading Pokémon...</p>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Main JS -->
    <script src="./js/main.js" defer></script>

</body>
</html>